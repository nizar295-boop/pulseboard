# Copier ce fichier en .env et remplir les valeurs

NODE_ENV=production
PORT=3000

# PostgreSQL — fourni automatiquement par Railway
DATABASE_URL=postgresql://user:password@host:5432/pulseboard

# Clé secrète pour les cookies JWT — générer une clé aléatoire longue
JWT_SECRET=change-this-to-a-long-random-secret-key
